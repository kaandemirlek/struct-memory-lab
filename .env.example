# ---------------------------------------------------------------------------
# AI Assistant layer (optional). The app works fully WITHOUT any of these:
# with no config it runs in deterministic "mock" mode (best-effort offline
# answers, no network) — ideal for the locked-down company machine.
#
# To enable live OpenAI chat, copy this file to .env.local, set AI_MODE=live,
# and provide a key. If a request fails (e.g. a corporate proxy blocks it), the
# route automatically falls back to mock mode. .env.local is gitignored.
# ---------------------------------------------------------------------------

# "mock" (default) or "live"
AI_MODE=mock

# Required only when AI_MODE=live
OPENAI_API_KEY=

# Optional; defaults to gpt-4o-mini (cheapest — good for a cost test)
OPENAI_MODEL=gpt-4o-mini

# Optional cost-estimate overrides, USD per 1,000,000 tokens. If unset, the
# route uses a built-in table for known models. Token counts come from the API
# response (exact); only these rates are an estimate — verify current prices at
# https://openai.com/api/pricing
# OPENAI_PRICE_IN=0.15
# OPENAI_PRICE_OUT=0.60
